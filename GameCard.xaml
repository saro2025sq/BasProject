<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="420" Height="180">
  <Border CornerRadius="12" Background="#121417" Padding="12" BorderBrush="#1F2937" BorderThickness="1" >
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="140"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" CornerRadius="10" Background="#0B0F14" >
        <Image Source="https://images.igdb.com/igdb/image/upload/t_cover_big/co1r8v.jpg"
               Stretch="UniformToFill" Opacity="0.95"/>
      </Border>

      <StackPanel Grid.Column="1" Margin="12,0,0,0">
        <TextBlock Text="Mythic Runner" Foreground="#E5E7EB" FontWeight="Bold" FontSize="18"/>
        <TextBlock Text="Ritüel‑temalı cyber arcade | 2026"
                   Foreground="#9CA3AF" Margin="0,4,0,10" FontSize="12"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
          <Border Background="#1F2937" CornerRadius="6" Padding="6,2" Margin="0,0,8,0">
            <TextBlock Text="Action" Foreground="#D1D5DB" FontSize="11"/>
          </Border>
          <Border Background="#1F2937" CornerRadius="6" Padding="6,2">
            <TextBlock Text="Single‑player" Foreground="#D1D5DB" FontSize="11"/>
          </Border>
        </StackPanel>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <TextBlock Text="€24.99" Foreground="#A7F3D0" FontWeight="SemiBold" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Content="Add to cart" Padding="14,6" Margin="10,0,0,0"
                  Background="#2563EB" Foreground="White" BorderBrush="#1E40AF" BorderThickness="1"
                  Cursor="Hand">
            <Button.Style>
              <Style TargetType="Button">
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="Button">
                      <Border Background="{TemplateBinding Background}"
                              CornerRadius="8"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
                <Setter Property="RenderTransform">
                  <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                  </Setter.Value>
                </Setter>
                <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>
        </Grid>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
